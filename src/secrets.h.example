#pragma once

// Copy this file to src/secrets.h and customize.
// src/secrets.h is gitignored.

// ESP32 is 2.4GHz-only — use a 2.4GHz SSID.
#define WIFI_SSID "mixpanel-guest"
#define WIFI_PASS "analytics"

// Flask dashboard host. Use mDNS (e.g. happyclinic.local) if your Mac has
// Bonjour on the same LAN, otherwise hardcode the dev machine's IP.
#define SERVER_HOST "happyclinic.local"
#define SERVER_PORT 5050

// Which patient this badge represents. Must match a key in the PATIENTS
// dict in tools/dashboard.py (e.g. "ana", "mark", "priya").
#define PATIENT_ID "mark"
